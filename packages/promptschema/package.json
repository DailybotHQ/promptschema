{
  "name": "promptschema",
  "version": "0.1.0",
  "description": "Typed, versioned prompts for LLMs — the Zod for AI prompts",
  "keywords": [
    "llm",
    "prompts",
    "ai",
    "zod",
    "typescript",
    "openai",
    "anthropic"
  ],
  "license": "MIT",
  "author": "Oscar",
  "repository": {
    "type": "git",
    "url": "https://github.com/DailybotHQ/promptschema",
    "directory": "packages/promptschema"
  },
  "homepage": "https://github.com/DailybotHQ/promptschema#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "promptschema": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "peerDependencies": {
    "zod": ">=3.0.0"
  },
  "dependencies": {
    "zod-to-json-schema": "^3.24.5"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^3",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "tsup": "^8",
    "typescript": "^5",
    "typescript-eslint": "^8.60.0",
    "vitest": "^3",
    "zod": "^3"
  }
}
