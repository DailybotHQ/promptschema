{
  "name": "promptschema",
  "version": "0.1.0",
  "description": "Typed, versioned prompts for LLMs — the Zod for AI prompts",
  "keywords": ["llm", "prompts", "ai", "zod", "typescript", "openai", "anthropic"],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "promptschema": "./dist/cli/index.js"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "zod": ">=3.0.0"
  },
  "dependencies": {
    "zod-to-json-schema": "^3.24.5"
  },
  "devDependencies": {
    "tsup": "^8",
    "vitest": "^3",
    "@vitest/coverage-v8": "^3",
    "zod": "^3",
    "typescript": "^5"
  }
}
